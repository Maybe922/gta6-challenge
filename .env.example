# 复制成 .env 后改成你自己的值：cp .env.example .env

# 后台登录密码（必改）
ADMIN_PASSWORD=change-this-now

# 服务端口（可选，默认 3000）
PORT=3000

# 今日战报：图像 / 口号生成（OpenAI 兼容中转）
CNAI_API_KEY=sk-xxxxxxxx
CNAI_BASE_URL=https://your-relay.example.com

# Telegram 记账 bot（可选，两个都填才会启动）
# 1) 找 @BotFather 建 bot 拿 token
# 2) 找 @userinfobot 拿你自己的数字 id（bot 只认这个 id）
TG_BOT_TOKEN=
TG_ALLOWED_USER_ID=
